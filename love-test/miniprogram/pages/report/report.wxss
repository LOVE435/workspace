.container {
  padding: 40rpx 40rpx 240rpx;
  min-height: 100vh;
}

.report-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 50rpx;
}

.archetype-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.archetype-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.archetype-summary {
  font-size: 28rpx;
  color: #999;
  font-style: italic;
  text-align: center;
  line-height: 1.5;
}

.section {
  margin-bottom: 32rpx;
  padding: 32rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e94560;
  display: block;
  margin-bottom: 16rpx;
}

.section-text {
  font-size: 28rpx;
  color: #ccc;
  line-height: 1.8;
  display: block;
}

.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  margin-top: 20rpx;
  padding: 40rpx 0 120rpx;
  border-top: 1rpx solid rgba(255,255,255,0.08);
}

.share-quote {
  padding: 20rpx 40rpx;
  background: rgba(233,69,96,0.1);
  border-radius: 40rpx;
  margin-bottom: 16rpx;
}

.quote-text {
  font-size: 28rpx;
  color: #ff6b81;
  font-style: italic;
}

.share-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #ff6b81, #e94560);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.retry-btn {
  width: 100%;
  height: 80rpx;
  background: transparent;
  color: #777;
  font-size: 28rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
