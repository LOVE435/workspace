.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.animation-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.heart { font-size: 100rpx; }

.dots {
  display: flex;
  gap: 16rpx;
  margin-top: 40rpx;
}

.dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  background: #e94560;
  animation: blink 1.4s ease-in-out infinite;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes blink {
  0%, 80%, 100% { opacity: 0.2; }
  40% { opacity: 1; }
}

.status-text {
  font-size: 36rpx; color: #fff; font-weight: 600;
  margin-bottom: 16rpx;
}

.hint { font-size: 26rpx; color: #666; }

.retry-btn {
  margin-top: 40rpx;
  width: 400rpx; height: 80rpx;
  background: linear-gradient(135deg, #e94560, #c23152);
  color: #fff; font-size: 28rpx; font-weight: 600;
  border-radius: 40rpx; border: none;
}
