.container {
  padding: 40rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.progress-bar {
  height: 6rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 3rpx;
  margin-bottom: 10rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #e94560, #ff6b81);
  border-radius: 3rpx;
  transition: width 0.4s ease;
}

.progress-text {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 40rpx;
  display: block;
}

.question-text {
  font-size: 38rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.4;
  display: block;
  margin-bottom: 40rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 50rpx;
}

.option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.option-selected {
  background: rgba(233,69,96,0.15);
  border-color: #e94560;
}

.option-label {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  color: #ccc;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-weight: 600;
}

.option-selected .option-label {
  background: #e94560;
  color: #fff;
}

.option-text {
  font-size: 26rpx;
  color: #ccc;
  line-height: 1.3;
}

.option-selected .option-text {
  color: #fff;
}

.next-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #e94560, #c23152);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  margin-top: 60rpx;
}

.btn-disabled {
  background: rgba(255,255,255,0.1);
  color: #666;
}
